{
  "name": "studybridge",
  "version": "0.1.0",
  "description": "WhatsApp-native Socratic tutoring webhook prototype.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc --noEmit false",
    "typecheck": "tsc --noEmit",
    "digest:weekly": "tsx src/jobs/sendWeeklyDigests.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20"
  }
}
